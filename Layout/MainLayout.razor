@inherits HTTLayoutComponentBase
@implements IAsyncDisposable

<div class="htt-shell @Theme.ThemeClass">
    <!-- ═══ Sidebar ═══ -->
    <HTTSidebar Id="sidebar" Visible="@(_sidebarState != CCollapseType.Hidden)" VisibleChanged="OnVisibleChanged"
                Collapsed="@(_sidebarState == CCollapseType.Collapsed)" CollapsedChanged="OnCollapsedChanged"
                Overlay="@(_isMobile && _sidebarState != CCollapseType.Hidden)">
        <Header>
            <!-- Brand -->
            <a class="sidebar-brand" href="/">
                <div class="sidebar-brand-icon">HTT</div>
                <div class="sidebar-brand-text">HTT <span>Enterprise</span></div>
            </a>
        </Header>

        <Body>
            <!-- Navigation -->
            <nav class="sidebar-nav" role="navigation" aria-label="Main navigation">

                <span class="sidebar-section-label">@L["Layout.Sidebar.Sections.Workspace"]</span>

                <NavLink class="sidebar-item" href="/" Match="NavLinkMatch.All">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>@L["Layout.Sidebar.Items.Dashboard"]</span>
                </NavLink>

                <NavLink class="sidebar-item" href="/analytics">
                    <i class="bi bi-bar-chart-line-fill"></i>
                    <span>@L["Layout.Sidebar.Items.Analytics"]</span>
                </NavLink>

                <NavLink class="sidebar-item" href="/projects">
                    <i class="bi bi-kanban-fill"></i>
                    <span>@L["Layout.Sidebar.Items.Projects"]</span>
                    <span class="nav-badge">3</span>
                </NavLink>

                <NavLink class="sidebar-item" href="/reports">
                    <i class="bi bi-file-earmark-bar-graph-fill"></i>
                    <span>@L["Layout.Sidebar.Items.Reports"]</span>
                </NavLink>

                <span class="sidebar-section-label">@L["Layout.Sidebar.Sections.Management"]</span>

                <NavLink class="sidebar-item" href="/users">
                    <i class="bi bi-people-fill"></i>
                    <span>@L["Layout.Sidebar.Items.Users"]</span>
                </NavLink>

                <NavLink class="sidebar-item" href="/billing">
                    <i class="bi bi-credit-card-fill"></i>
                    <span>@L["Layout.Sidebar.Items.Billing"]</span>
                </NavLink>

                <NavLink class="sidebar-item" href="/integrations">
                    <i class="bi bi-plug-fill"></i>
                    <span>@L["Layout.Sidebar.Items.Integrations"]</span>
                </NavLink>

                <span class="sidebar-section-label">@L["Layout.Sidebar.Sections.System"]</span>

                <NavLink class="sidebar-item" href="/audit">
                    <i class="bi bi-shield-check"></i>
                    <span>@L["Layout.Sidebar.Items.AuditLog"]</span>
                </NavLink>

                <NavLink class="sidebar-item" href="/settings">
                    <i class="bi bi-sliders2"></i>
                    <span>@L["Layout.Sidebar.Items.Settings"]</span>
                </NavLink>

            </nav>
        </Body>
        <Footer>
            <!-- User Footer -->
            <div class="sidebar-footer">
                <a class="sidebar-user" href="/profile">
                    <div class="user-avatar">AD</div>
                    <div class="user-info">
                        <div class="user-name">@L["Layout.Sidebar.User.Name"]</div>
                        <div class="user-role">@L["Layout.Sidebar.User.Role"]</div>
                    </div>
                    <i class="bi bi-three-dots-vertical ms-auto"
                       style="color: var(--htt-text-muted); font-size:0.875rem;"></i>
                </a>
            </div>
        </Footer>
    </HTTSidebar>

    <!-- ═══ Main ═══ -->
    <div class="htt-main">

        <!-- Top Bar -->
        <header class="htt-topbar">
            <!-- Hamburger Toggle -->
            <HTTButton Variant="CButtonVariant.Ghost" Size="CButtonSize.Small" Class="topbar-btn me-2"
                       OnClick="ToggleSidebar" IconOnly="true" Icon="@($"bi {GetToggleIcon()}")"
                       ToolTip="@(_sidebarState.GetLocalizedName(L))" />

            <div class="topbar-title">
                @PageTitle
                <span class="badge bg-secondary ms-2"
                      style="font-size: 0.5rem; vertical-align: middle;">@_sidebarState</span>
            </div>

            <div class="topbar-search">
                <HTTInput TValue="string" Type="CInputType.Search" Placeholder="@L["Layout.Topbar.SearchPlaceholder"]"
                          @bind-Value="_searchQuery" Size="CSpacingType.SM" Icon="bi bi-search" aria-label="Global search" />
            </div>

            <div class="topbar-actions">
                <HTTToolTip Position="CPositionType.Top" Shape="CToolTipShapeType.Bubble"
                            Text="@L.GetString("Layout.Topbar.Theme", Theme.CurrentTheme.GetLocalizedName(L))">
                    <HTTButton Variant="CButtonVariant.Ghost" Size="CButtonSize.Small" Class="topbar-btn me-2"
                               OnClick="Theme.ToggleThemeAsync" IconOnly="true" Icon="@($"bi {Theme.CurrentTheme.GetIcon()}")"
                               aria-label="Toggle Theme" />
                </HTTToolTip>

                <HTTLanguageSelector />

                <HTTToolTip Position="CPositionType.Top" Text="@L["Layout.Topbar.Notifications"]">
                    <HTTButton Variant="CButtonVariant.Ghost" Size="CButtonSize.Small" Class="topbar-btn"
                               Icon="bi bi-bell-fill" IconOnly="true" aria-label="Notifications">
                        <span class="topbar-notif-dot"></span>
                    </HTTButton>
                </HTTToolTip>

                <HTTToolTip Position="CPositionType.Top" Text="@L["Layout.Topbar.Messages"]">
                    <HTTButton Variant="CButtonVariant.Ghost" Size="CButtonSize.Small" Class="topbar-btn"
                               IconOnly="true" Icon="bi bi-chat-dots-fill" aria-label="Messages" />
                </HTTToolTip>

                <HTTToolTip Position="CPositionType.Top" Text="@L["Layout.Topbar.Help"]">
                    <HTTButton Variant="CButtonVariant.Ghost" Size="CButtonSize.Small" Class="topbar-btn"
                               IconOnly="true" Icon="bi bi-question-circle-fill" aria-label="Help" />
                </HTTToolTip>

                <HTTToolTip Position="CPositionType.Top" Text="@L["Layout.Topbar.Profile"]">
                    <HTTButton Variant="CButtonVariant.Ghost" Size="CButtonSize.Small" Class="topbar-btn"
                               IconOnly="true" Icon="bi bi-person-circle" OnClick="@(() => Nav.NavigateTo("/profile"))"
                               aria-label="Profile" />
                </HTTToolTip>
            </div>
        </header>


        <!-- Page Content -->
        <main class="htt-content" role="main">
            @Body
        </main>

    </div>
</div>