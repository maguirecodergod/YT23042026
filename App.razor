<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>404 — Not Found | HTT Enterprise</PageTitle>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <div class="htt-content fade-in">
                <div class="page-header">
                    <div class="htt-breadcrumb">
                        <a href="/">Home</a>
                        <i class="bi bi-chevron-right separator"></i>
                        <span class="current">Not Found</span>
                    </div>
                    <h1>404 — Page Not Found</h1>
                    <p>The resource you're looking for doesn't exist or has been moved.</p>
                </div>
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-house-fill"></i> Back to Dashboard
                </a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
