@page "/"
@inherits HTTComponentBase
@inject HttpClient Http
<PageTitle>Dashboard — HTT Enterprise</PageTitle>

<HTTContainer Padding="CSpacingType.LG" MaxWidth="1440px">
    <div class="fade-in">
        <!-- Page Header -->
        <HTTStack Spacing="CSpacingType.XS" Class="page-header mb-4">
            <HTTBreadcrumb Items="_breadcrumbs" />
            <HTTHeading Type="CHeadingType.H1" ToolTip="Welcome back, we've missed you! ✨"
                        ToolTipShape="CToolTipShapeType.Cute">
                Good morning, Admin <span class="text-gradient-gold">👋</span>
            </HTTHeading>
            <p>Here's what's happening across your enterprise platform today.</p>
        </HTTStack>

        <!-- User Picker Showcase Row (New) -->
        <div class="mb-4">
            <HTTCard>
                <Header>
                    <HTTHeading Type="CHeadingType.H2" Class="htt-card-title m-0">
                        <i class="bi bi-people-fill me-2" style="color:var(--htt-gold)"></i>Enterprise User Picker
                        Showcase
                    </HTTHeading>
                </Header>

                <Body>
                    <div class="grid gap-6" style="grid-template-columns: 1fr 1fr;">
                        <div>
                            <HTTLabel Class="mb-2 d-block">Enterprise Search (API Scroll Paging)</HTTLabel>
                            <HTTUserPicker @bind-SelectedUsers="@_selectedSingle" Multiple="false"
                                           EnablePagination="true" PageSize="10" LoadData="@LoadUsersApi"
                                           Placeholder="Tìm kiếm thành viên (API)..." />
                            @if (_selectedSingle.Any())
                            {
                                <div class="mt-2" style="font-size: 0.75rem; color: var(--color-text-secondary)">
                                    Selected ID: @_selectedSingle.First().Id
                                </div>
                            }
                        </div>
                        <div>
                            <HTTLabel Class="mb-2 d-block">Team Selection (Client Side)</HTTLabel>
                            <HTTUserPicker Users="@_testUsers" @bind-SelectedUsers="@_selectedTeam" Multiple="true"
                                           MaxTagsToShow="3"
                                           ShowSelectedPanel="true"
                                           Placeholder="Chọn các thành viên vào team..." Loading="@_isUsersLoading" />
                            @if (_selectedTeam.Any())
                            {
                                <div class="mt-2" style="font-size: 0.75rem; color: var(--color-text-secondary)">
                                    Team size: @_selectedTeam.Count members
                                </div>
                            }
                        </div>
                    </div>
                </Body>
            </HTTCard>
        </div>

        <!-- Content Grid -->
        <div class="grid gap-4" style="grid-template-columns: 1fr 360px;">

            <!-- Recent Activity -->
            <HTTCard Hoverable="true">
                <Header>
                    <HTTHeading Type="CHeadingType.H2" Class="htt-card-title m-0">
                        <i class="bi bi-clock-history me-2" style="color:var(--htt-gold)"></i>Recent Activity
                    </HTTHeading>
                </Header>
                <Actions>
                    <HTTButton Variant="CButtonVariant.Secondary" Size="CButtonSize.Small" Text="View All" />
                </Actions>

                <Body>
                    <HTTGrid TItem="ActivityItem" Items="_activityItems" Selectable="false" Virtualize="false"
                             ShowPagination="false">
                        <HTTColumn TItem="ActivityItem" Title="Event">
                            <CellTemplate Context="item">
                                <div style="font-weight:500">@item.Event</div>
                                <div style="font-size:0.75rem;color:var(--htt-text-muted)">@item.Description</div>
                            </CellTemplate>
                        </HTTColumn>
                        <HTTColumn TItem="ActivityItem" Title="User">
                            <CellTemplate Context="item">
                                <div class="cluster gap-2">
                                    <div
                                        style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#3b82f6,#8b5cf6);display:flex;align-items:center;justify-content:center;font-size:0.625rem;font-weight:700;color:white;flex-shrink:0">
                                        @item.User[..2].ToUpper()
                                    </div>
                                    <span style="font-size:0.875rem">@item.User</span>
                                </div>
                            </CellTemplate>
                        </HTTColumn>
                        <HTTColumn TItem="ActivityItem" Title="Status">
                            <CellTemplate Context="item">
                                <span class="htt-badge @item.BadgeClass">@item.Status</span>
                            </CellTemplate>
                        </HTTColumn>
                        <HTTColumn TItem="ActivityItem" Title="Time">
                            <CellTemplate Context="item">
                                <span style="color:var(--htt-text-muted);font-size:0.8125rem">@item.Time</span>
                            </CellTemplate>
                        </HTTColumn>
                    </HTTGrid>
                </Body>
            </HTTCard>

            <!-- Quick Actions + System Status -->
            <HTTStack Spacing="CSpacingType.MD">

                <!-- Quick Actions -->
                <HTTCard Class="htt-card-glow" Hoverable="true">
                    <Header>
                        <HTTHeading Type="CHeadingType.H2" Class="htt-card-title m-0">
                            <i class="bi bi-lightning-charge-fill me-2" style="color:var(--htt-gold)"></i>Quick Actions
                        </HTTHeading>
                    </Header>

                    <Body>
                        <HTTStack Spacing="CSpacingType.SM">
                            <HTTButton Variant="CButtonVariant.Primary" Block="true" Icon="bi bi-plus-circle-fill"
                                       Text="New Project" ToolTip="Create a new workspace project"
                                       ToolTipPosition="CPositionType.Top" ToolTipShape="CToolTipShapeType.Pill" />

                            <HTTButton Variant="CButtonVariant.Secondary" Block="true" Icon="bi bi-person-plus-fill"
                                       Text="Invite Member" ToolTip="Add a new member to this organization"
                                       ToolTipPosition="CPositionType.Top" ToolTipShape="CToolTipShapeType.Cute" />

                            <HTTButton Variant="CButtonVariant.Outline" Block="true" Icon="bi bi-window-stack"
                                       Text="Test Modal" OnClick="OpenTestModal" ToolTip="Test the new enterprise modal system"
                                       ToolTipPosition="CPositionType.Top" ToolTipShape="CToolTipShapeType.Bubble" />
                        </HTTStack>
                    </Body>
                </HTTCard>

                <!-- Toast Notifications -->
                <HTTCard Hoverable="true">
                    <Header>
                        <HTTHeading Type="CHeadingType.H2" Class="htt-card-title m-0">
                            <i class="bi bi-bell-fill me-2" style="color:var(--htt-gold)"></i>Notification System
                        </HTTHeading>
                    </Header>

                    <Body>
                        <div class="grid gap-2" style="grid-template-columns: 1fr 1fr;">
                            <HTTButton Variant="CButtonVariant.Success" Size="CButtonSize.Small" Text="Success"
                                       Icon="bi bi-check-circle" OnClick="@(() => ShowToast(CToastType.Success))" />

                            <HTTButton Variant="CButtonVariant.Danger" Size="CButtonSize.Small" Text="Error"
                                       Icon="bi bi-x-circle" OnClick="@(() => ShowToast(CToastType.Error))" />

                            <HTTButton Variant="CButtonVariant.Warning" Size="CButtonSize.Small" Text="Warning"
                                       Icon="bi bi-exclamation-triangle" OnClick="@(() => ShowToast(CToastType.Warning))" />

                            <HTTButton Variant="CButtonVariant.Info" Size="CButtonSize.Small" Text="Info"
                                       Icon="bi bi-info-circle" OnClick="@(() => ShowToast(CToastType.Info))" />

                            <HTTButton Variant="CButtonVariant.Outline" Size="CButtonSize.Small" Text="Custom Toast"
                                       Block="true" style="grid-column: span 2" Icon="bi bi-gear-wide-connected"
                                       OnClick="ShowCustomToast" />
                        </div>
                    </Body>
                </HTTCard>
                <HTTCard Hoverable="true">
                    <Header>
                        <HTTHeading Type="CHeadingType.H2" Class="htt-card-title m-0">
                            <i class="bi bi-activity me-2" style="color:var(--htt-gold)"></i>System Health
                        </HTTHeading>
                    </Header>
                    <Actions>
                        <span class="htt-badge htt-badge-green"><i class="bi bi-check-circle-fill"></i>
                            Operational</span>
                    </Actions>

                    <Body>
                        <HTTStack Spacing="CSpacingType.MD">
                            @foreach (var svc in _services)
                            {
                                <div>
                                    <div class="spread mb-1">
                                        <span style="font-size:0.8125rem;font-weight:500">@svc.Name</span>
                                        <span style="font-size:0.75rem;color:@svc.Color;font-weight:600">@svc.Uptime</span>
                                    </div>
                                    <HTTProgressBar Value="@svc.Pct" 
                                                  Variant="@(svc.Pct > 99 ? CButtonVariant.Success : CButtonVariant.Warning)"
                                                  ProgressType="CHTTProgressType.Gradient"
                                                  Size="CButtonSize.Small" />
                                </div>
                            }
                        </HTTStack>
                    </Body>
                </HTTCard>
            </HTTStack>
        </div>

        <!-- Progress Components Showcase (New) -->
        <div class="grid gap-4 mt-4" style="grid-template-columns: 1fr 1fr 1fr;">
            <HTTCard>
                <Header>
                    <HTTHeading Type="CHeadingType.H3" Class="m-0">Linear Progress</HTTHeading>
                </Header>
                <Body>
                    <HTTStack Spacing="CSpacingType.MD">
                        <div>
                            <HTTLabel Class="mb-1 d-block">Indeterminate (Loading)</HTTLabel>
                            <HTTProgressBar IsIndeterminate="true" ProgressType="CHTTProgressType.Animated" Variant="CButtonVariant.Primary" />
                        </div>
                        <div>
                            <HTTLabel Class="mb-1 d-block">Striped & Animated</HTTLabel>
                            <HTTProgressBar Value="75" ProgressType="CHTTProgressType.Animated" Variant="CButtonVariant.Success" ShowPercentage="true" />
                        </div>
                        <div>
                            <HTTLabel Class="mb-1 d-block">Stepped Progress</HTTLabel>
                            <HTTProgressBar Value="3" Max="5" ProgressType="CHTTProgressType.Stepped" Variant="CButtonVariant.Info" />
                        </div>
                    </HTTStack>
                </Body>
            </HTTCard>

            <HTTCard>
                <Header>
                    <HTTHeading Type="CHeadingType.H3" Class="m-0">Radial Progress</HTTHeading>
                </Header>
                <Body>
                    <div class="cluster gap-6 justify-center py-4">
                        <HTTProgressCircle Value="65" SizePx="80" Thickness="8" Variant="CButtonVariant.Primary" />
                        <HTTProgressCircle IsIndeterminate="true" SizePx="80" Thickness="8" Variant="CButtonVariant.Warning" />
                        <HTTProgressCircle Value="100" SizePx="80" Thickness="8" Variant="CButtonVariant.Success" />
                    </div>
                </Body>
            </HTTCard>

            <HTTCard>
                <Header>
                    <HTTHeading Type="CHeadingType.H3" Class="m-0">Stack & Storage</HTTHeading>
                </Header>
                <Body>
                    <HTTStack Spacing="CSpacingType.LG">
                        <div>
                            <HTTLabel Class="mb-2 d-block">Storage Distribution</HTTLabel>
                            <HTTProgressStack Segments="_storageSegments" Size="CButtonSize.Large" />
                        </div>
                        <div class="grid gap-2" style="grid-template-columns: repeat(2, 1fr);">
                            @foreach (var segment in _storageSegments)
                            {
                                <div class="cluster gap-2">
                                    <div style="width:12px; height:12px; border-radius:3px; background-color: var(--color-@(segment.Variant.ToString().ToLower()))"></div>
                                    <span style="font-size:0.75rem">@segment.Label: @segment.Value%</span>
                                </div>
                            }
                        </div>
                    </HTTStack>
                </Body>
            </HTTCard>
        </div>
    </div>
</HTTContainer>

@code {
    [Inject] private IHTTModalService ModalService { get; set; } = default!;
    record ActivityItem(string Event, string Description, string User, string Status, string BadgeClass, string Time);
    record ServiceItem(string Name, string Uptime, int Pct, string Color, string ColorLight);
    record StatItem(string Value, string Label, string Icon, string IconWrapClass, string ChangeClass, string ChangeIcon,
string ChangeText, string ProgressStyle);

    private List<HTTBreadcrumbItem> _breadcrumbs = new()
    {
        new() { Href = "/", Icon = "bi bi-grid-1x2-fill" },
        new() { Text = "Dashboard", IsActive = true }
    };

    private List<HTTProgressSegment> _storageSegments = new()
    {
        new() { Value = 45, Variant = CButtonVariant.Primary, Label = "Apps", ToolTip = "45GB of Apps" },
        new() { Value = 25, Variant = CButtonVariant.Success, Label = "Photos", ToolTip = "25GB of Photos" },
        new() { Value = 15, Variant = CButtonVariant.Warning, Label = "Docs", ToolTip = "15GB of Documents" },
        new() { Value = 10, Variant = CButtonVariant.Danger, Label = "Other", ToolTip = "10GB of System files" }
    };

    private List<StatItem> _stats = new()
    {
        new("$2.4M", "Total Revenue", "bi bi-currency-dollar", "stat-icon-wrap stat-icon-gold", "stat-change up", "bi bi-arrow-up-short", "12.4%", "width:72%"),
        new("14,832", "Active Users", "bi bi-people-fill", "stat-icon-wrap stat-icon-blue", "stat-change up", "bi bi-arrow-up-short", "8.1%", "width:58%; background: linear-gradient(90deg, var(--htt-blue), var(--htt-blue-light));"),
        new("248", "Active Projects", "bi bi-kanban-fill", "stat-icon-wrap stat-icon-green", "stat-change up", "bi bi-arrow-up-short", "3.7%", "width:85%; background: linear-gradient(90deg, #3fb950, #56d364);"),
        new("17", "Open Incidents", "bi bi-exclamation-circle-fill", "stat-icon-wrap stat-icon-red", "stat-change down", "bi bi-arrow-down-short", "2.3%", "width:17%; background: linear-gradient(90deg, #f85149, #ff7b72);")
    };

    private List<ActivityItem> _activityItems = new()
    {
        new("Deployment pushed", "v2.14.0 → Production", "John Smith", "Success", "htt-badge-green", "2 min ago"),
        new("User role updated", "RBAC policy change", "Sarah Lee", "Pending", "htt-badge-gold", "18 min ago"),
        new("Backup completed", "DB snapshot saved", "System", "Done", "htt-badge-blue", "1 hr ago"),
        new("Alert triggered", "CPU spike on node-07", "Monitor Bot", "Warning", "htt-badge-red", "2 hr ago"),
        new("API key rotated", "Credentials updated", "Admin User", "Success", "htt-badge-green", "4 hr ago"),
    };

    private List<ServiceItem> _services = new()
    {
        new("API Gateway", "99.98%", 100, "#3fb950", "#56d364"),
        new("Auth Service", "99.95%", 99, "#3fb950", "#56d364"),
        new("Database", "99.87%", 99, "#d29922", "#e3b341"),
        new("CDN / Storage", "100%", 100, "#3fb950", "#56d364"),
        new("Message Queue", "98.2%", 98, "#3fb950", "#56d364"),
    };

    private List<UserBaseModel> _testUsers = new();
    private List<UserBaseModel> _selectedSingle = new();
    private List<UserBaseModel> _selectedTeam = new();
    private bool _isUsersLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isUsersLoading = true;
            // Giả lập call API lấy data từ json file
            var users = await Http.GetFromJsonAsync<List<UserBaseModel>>("sample-data/users.json");
            if (users != null)
            {
                _testUsers = users;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching users: {ex.Message}");
            Toast.ShowError("Không thể tải danh sách thành viên", "Lỗi API");
        }
        finally
        {
            _isUsersLoading = false;
        }
    }

    private async Task<UserPickerLoadResponse> LoadUsersApi(UserPickerLoadRequest request)
    {
        // 1. Thực hiện Network Request thực thụ để hiển thị trong tab Network
        // Thêm Guid để tránh Browser Cache, buộc phải gọi lên server
        var allUsers = await Http.GetFromJsonAsync<List<UserBaseModel>>($"sample-data/users.json?t={Guid.NewGuid()}");

        // 2. Giả lập độ trễ mạng
        await Task.Delay(1000);

        var query = (allUsers ?? new()).AsQueryable();

        // 3. Giả lập Server-side Search
        if (!string.IsNullOrWhiteSpace(request.SearchText))
        {
            query = query.Where(u =>
                (u.FullName != null && u.FullName.Contains(request.SearchText, StringComparison.OrdinalIgnoreCase)) ||
                (u.Email != null && u.Email.Contains(request.SearchText, StringComparison.OrdinalIgnoreCase))
            );
        }

        var totalCount = query.Count();

        // 4. Giả lập Server-side Pagination
        var items = query.Skip((request.PageIndex - 1) * request.PageSize)
                         .Take(request.PageSize)
                         .ToList();

        return new UserPickerLoadResponse
        {
            Items = items,
            TotalCount = totalCount
        };
    }

    // Helper classes for ReqRes API
    public class ReqResResponse
    {
        public int Total { get; set; }
        public List<ReqResUser> Data { get; set; } = new();
    }

    public class ReqResUser
    {
        public int Id { get; set; }
        public string Email { get; set; } = "";
        public string First_Name { get; set; } = "";
        public string Last_Name { get; set; } = "";
        public string Avatar { get; set; } = "";
    }

    private async Task OpenTestModal()
    {
        var result = await ModalService.ShowAsync<HTT.BlazorWasm.App.Components.ConfirmDialog>(new ModalOptions
        {
            Title = L["Common.Dialog.DeleteTitle"],
            Parameters = new Dictionary<string, object>
            {
                { "Message", L["Common.Dialog.DeleteMessage"].ToString() }
            },
            Width = "450px"
        });

        if (result.Confirmed)
        {
            Toast.ShowSuccess(L["Common.Action.SuccessMessage"], L["Common.Action.SuccessTitle"]);
        }
    }

    private int _toastCounter = 0;
    private void ShowToast(CToastType type)
    {
        _toastCounter++;
        var timestamp = DateTime.Now.ToString("HH:mm:ss");

        switch (type)
        {
            case CToastType.Success:
                Toast.ShowSuccess($"[{_toastCounter}] Operation completed at {timestamp}", "Success");
                break;
            case CToastType.Error:
                Toast.ShowError($"[{_toastCounter}] Critical failure occurred at {timestamp}", "Critical Error");
                break;
            case CToastType.Warning:
                Toast.ShowWarning($"[{_toastCounter}] System warning logged at {timestamp}", "Warning");
                break;
            case CToastType.Info:
                Toast.ShowInfo($"[{_toastCounter}] New update available at {timestamp}", "Information");
                break;
        }
    }

    private void ShowCustomToast()
    {
        Toast.ShowCustom(new ToastModel
        {
            Title = "Custom Action",
            Message = "Would you like to review the latest logs?",
            Type = CToastType.Info,
            Icon = "bi bi-journal-text",
            ActionText = "Review",
            OnActionClick = () => Toast.ShowInfo("Opening logs..."),
            Duration = 10000,
            Position = CToastPosition.BottomRight
        });
    }
}
