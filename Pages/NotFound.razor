@page "/not-found"
<PageTitle>404 — Not Found | HTT Enterprise</PageTitle>

<div class="fade-in" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;gap:1.5rem">
    <div style="font-size:5rem;line-height:1;font-family:var(--font-display);font-weight:800;color:var(--htt-text-muted)">404</div>
    <div>
        <h1 style="font-size:1.5rem;margin-bottom:0.5rem">Page not found</h1>
        <p style="color:var(--htt-text-secondary)">The resource you requested doesn't exist or you don't have access.</p>
    </div>
    <a href="/" class="btn btn-primary">
        <i class="bi bi-house-fill"></i> Return to Dashboard
    </a>
</div>
