@typeparam TItem
@inherits HTTComponentBase

<CascadingValue Value="this" IsFixed="true">
    @ChildContent
</CascadingValue>

<div class="htt-grid-container htt-grid-container--@DisplayMode.ToString().ToLower()" id="@Id"
     style="--htt-grid-template: @GetGridTemplateColumns(); --htt-card-min-width: @(CardMinWidth)px;">

    <div class="htt-grid-wrapper">
        <div class="htt-grid" role="@(DisplayMode == HTTGridDisplayMode.Table ? "grid" : "list")">

            @if (DisplayMode == HTTGridDisplayMode.Table)
            {
                <div class="htt-grid__header">
                    @if (Selectable && MultiSelect)
                    {
                        <div class="htt-grid__header-cell htt-grid__header-cell--selection">
                            @* Checkbox for select all *@
                        </div>
                    }
                    @foreach (var col in _columns.Where(c => c.Visible))
                    {
                        <div class="@GetHeaderClass(col)" @onclick="() => SortBy(col)" role="columnheader"
                             aria-sort="@(col.Sortable ? "none" : null)">
                            <div class="htt-grid__header-content">
                                @if (col.HeaderTemplate != null)
                                {
                                    @col.HeaderTemplate
                                }
                                else
                                {
                                    <span class="htt-grid__header-text">@col.Title</span>
                                }
                                @if (col.Sortable)
                                {
                                    <div class="htt-grid__sort-icon"></div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="htt-grid__body">
                @if (Virtualize)
                {
                    <Virtualize @ref="_virtualizeComponent" Items="_viewItems" Context="item" ItemSize="ItemSize">
                        @RenderItem(item)
                    </Virtualize>
                }
                else
                {
                    @foreach (var item in _viewItems)
                    {
                        @RenderItem(item)
                    }
                }
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="htt-grid__loading-overlay">
                <div class="htt-grid__spinner"></div>
            </div>
        }
    </div>

    @* Premium Pagination Footer *@
    <div class="htt-grid__footer">
        <div class="htt-grid__footer-left">
            <span class="htt-grid__total-label">
                @L["Common.Grid.Total"] <strong>@_totalCount</strong> @L["Common.Grid.Items"]
            </span>
            <div class="htt-grid__page-size">
                <span>@L["Common.Grid.Show"]</span>
                <div class="htt-grid__page-size-select">
                    <HTTSelect TItem="int" TValue="int" Items="_pageSizeOptions" Value="_state.PageSize"
                               ValueChanged="OnPageSizeChanged" Searchable="false" AllowClear="false" ShowArrow="true"
                               Placeholder="" />
                </div>
            </div>
        </div>

        <div class="htt-grid__pagination">
            <HTTToolTip Content="@L["Common.Grid.FirstPage"]">
                <button class="htt-grid__page-btn" disabled="@(_state.PageIndex == 0)"
                        @onclick="() => OnPageChanged(0)">
                    <i class="bi-chevron-double-left"></i>
                </button>
            </HTTToolTip>

            <HTTToolTip Content="@L["Common.Grid.Previous"]">
                <button class="htt-grid__page-btn" disabled="@(_state.PageIndex == 0)"
                        @onclick="() => OnPageChanged(_state.PageIndex - 1)">
                    <i class="bi-chevron-left"></i>
                </button>
            </HTTToolTip>

            <div class="htt-grid__page-numbers">
                @foreach (var p in GetVisiblePages())
                {
                    if (p == -1)
                    {
                        <span class="htt-grid__page-ellipsis">...</span>
                    }
                    else
                    {
                        var pageIndex = p;
                        <button class="htt-grid__page-btn @(pageIndex == _state.PageIndex ? "is-active" : "")"
                                @onclick="() => OnPageChanged(pageIndex)">
                            @(pageIndex + 1)
                        </button>
                    }
                }
            </div>

            <HTTToolTip Content="@L["Common.Grid.Next"]">
                <button class="htt-grid__page-btn" disabled="@((_state.PageIndex + 1) * _state.PageSize >= _totalCount)"
                        @onclick="() => OnPageChanged(_state.PageIndex + 1)">
                    <i class="bi-chevron-right"></i>
                </button>
            </HTTToolTip>

            <HTTToolTip Content="@L["Common.Grid.LastPage"]">
                <button class="htt-grid__page-btn" disabled="@((_state.PageIndex + 1) * _state.PageSize >= _totalCount)"
                        @onclick="() => OnPageChanged((int)Math.Ceiling((double)_totalCount / _state.PageSize) - 1)">
                    <i class="bi-chevron-double-right"></i>
                </button>
            </HTTToolTip>
        </div>
    </div>
</div>

@code {
    private RenderFragment RenderItem(TItem item) => __builder =>
    {
        var isSelected = _state.SelectedItems.Contains(item);
        var isExpanded = _state.ExpandedRows.Contains(item);

        @if (DisplayMode == HTTGridDisplayMode.Table)
        {
            <div class="htt-grid__row @(isSelected ? "htt-grid__row--selected" : "")" @key="item"
                 @onclick="() => ToggleRowSelection(item)" role="row" aria-selected="@isSelected">

                @if (Selectable && MultiSelect)
                {
                    <div class="htt-grid__cell htt-grid__cell--selection">
                        <input type="checkbox" checked="@isSelected" @onchange="() => ToggleRowSelection(item)" />
                    </div>
                }

                @foreach (var col in _columns.Where(c => c.Visible))
                {
                    <div class="htt-grid__cell" role="gridcell">
                        @if (col.CellTemplate != null)
                        {
                            @col.CellTemplate(item)
                        }
                        else
                        {
                            @col.GetValue(item)
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="htt-grid__card @(isSelected ? "htt-grid__card--selected" : "")" @key="item"
                 @onclick="() => ToggleRowSelection(item)" role="listitem">
                @if (CardTemplate != null)
                {
                    @CardTemplate(item)
                }
                else
                {
                    <div class="htt-grid__card-content">
                        @foreach (var col in _columns.Where(c => c.Visible))
                        {
                            <div class="htt-grid__card-field">
                                <label>@col.Title:</label>
                                <span>@col.GetValue(item)</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (isExpanded && DetailTemplate != null)
        {
            <div class="htt-grid__row-detail">
                @DetailTemplate(item)
            </div>
        }
    };
}
